# LeadForge AI Frontend — Environment Variables
#
# Vite exposes vars prefixed with VITE_ to the client bundle.
# All other vars are server-only at build time.

# Backend API base URL (used by apiClient.ts in production)
# In development this is proxied via Vite (see vite.config.ts proxy).
# For production builds, set this to the deployed backend origin.
VITE_API_BASE_URL=https://api.your-domain.com
