# ==============================================================================
# LeadForge AI - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in the values for your environment.
# Do NOT commit the '.env' file containing real secrets to version control.

# System Configurations
ENV=production
DEBUG=false
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Security & JWT Tokens
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_signing_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# Use postgresql:// for non-async clients, settings validator will convert it to postgresql+asyncpg://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadforge_ai

# Local Screenshot Directory
SCREENSHOTS_DIR=app/static/screenshots

# External API Integrations (Optional if overridden per-user in DB settings)
SERPAPI_KEY=your_serpapi_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
