# ==============================================================================
# LeadForge AI — Production Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in all values before deploying.
# Never commit `.env` to version control.
#
# Quick reference:
#   openssl rand -hex 32   → generate JWT_SECRET
#   openssl rand -hex 64   → generate DB password
# ==============================================================================

# ── System ──────────────────────────────────────────────────────
ENV=production
DEBUG=false
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins.
# For production: https://your-frontend-domain.com
# For local dev:  http://localhost:3000,http://localhost:8000
CORS_ORIGINS=https://your-frontend-domain.com

# ── Security & JWT ──────────────────────────────────────────────
# Generate via: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database (PostgreSQL) ──────────────────────────────────────
# The validator in app/core/config.py automatically converts
# postgresql:// → postgresql+asyncpg:// so you can write the
# standard connection string here.
DATABASE_URL=postgresql://user:password@host:5432/leadforge_ai

# ── Local Screenshots ──────────────────────────────────────────
SCREENSHOTS_DIR=app/static/screenshots

# ── SerpAPI (Google Maps lead discovery) ───────────────────────
# Get your free API key at https://serpapi.com/manage-api-key
SERPAPI_KEY=

# ── Groq (AI inference — audit, scoring, outreach, generation) ──
# Get your API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Cloudinary (screenshot hosting) ─────────────────────────────
# Create a free account at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stitch Design Service (automated website generation) ───────
# Separate Railway service wrapping @google/stitch-sdk (TypeScript).
# See stitch-service/.env.example for the service's own env vars.
#
# URL of the running stitch-service (Railway internal URL or localhost)
STITCH_SERVICE_URL=http://127.0.0.1:3100
# Shared secret — must match STITCH_SERVICE_SECRET in stitch-service
STITCH_SERVICE_SECRET=change-me-to-a-random-string
# Timeout (seconds) for a single Stitch generation call from the Python side
STITCH_GENERATE_TIMEOUT=360
