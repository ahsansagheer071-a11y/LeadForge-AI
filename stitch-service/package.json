{
  "name": "leadforge-stitch-service",
  "version": "1.0.0",
  "description": "Internal TypeScript service wrapping @google/stitch-sdk for LeadForge",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/stitch-sdk": "0.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
