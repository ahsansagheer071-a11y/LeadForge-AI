# ── Stitch Service Environment ───────────────────────────────────
# Railway sets PORT automatically; override only for local dev.
PORT=3100
STITCH_SERVICE_PORT=3100

# REQUIRED — Google Stitch API key.  Service exits immediately if unset.
STITCH_API_KEY=

# Internal shared secret between Python backend and this service.
# Must match STITCH_SERVICE_SECRET in the Python backend.
STITCH_SERVICE_SECRET=leadforge-internal-shared-secret

# Max time (ms) to wait for a single Stitch generation + HTML fetch.
# The request-level timeout is this value + 30s buffer.
STITCH_TIMEOUT_MS=300000
